{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "python_bot/api/bot.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/api/index.js"
    },
    {
      "source": "/bot/(.*)",
      "destination": "python_bot/api/bot.py"
    },
    {
      "source": "/login",
      "destination": "frontend/index.html"
    },
    {
      "source": "/register",
      "destination": "frontend/index.html"
    },
    {
      "source": "/dashboard",
      "destination": "frontend/index.html"
    },
    {
      "source": "/wallet",
      "destination": "frontend/index.html"
    },
    {
      "source": "/groups",
      "destination": "frontend/index.html"
    },
    {
      "source": "/campaigns",
      "destination": "frontend/index.html"
    },
    {
      "source": "/admin",
      "destination": "frontend/index.html"
    },
    {
      "source": "/superadmin",
      "destination": "frontend/index.html"
    },
    {
      "source": "/(.*)\\.(js|css|png|jpg|svg|ico)",
      "destination": "frontend/$1.$2"
    },
    {
      "source": "/((?!api|bot|static).*)",
      "destination": "frontend/index.html"
    }
  ]
}