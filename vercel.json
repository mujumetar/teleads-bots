{
  "version": 2,
  "installCommand": "cd backend && npm install && cd ../frontend && npm install",
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "functions": {
    "api/bot.py": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    {
      "source": "/api/bot",
      "destination": "/api/bot"
    },
    {
      "source": "/api/bot/(.*)",
      "destination": "/api/bot"
    },
    {
      "source": "/bot",
      "destination": "/api/bot"
    },
    {
      "source": "/bot/(.*)",
      "destination": "/api/bot"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
